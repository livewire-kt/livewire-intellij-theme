<idea-plugin>
    <id>com.livewire.theme</id>
    <name>Livewire Theme</name>
    <vendor url="https://github.com/livewire-kt">Livewire</vendor>
    <category>Theme</category>
    <description><![CDATA[
        Livewire brand theme for JetBrains IDEs — dark and light UI themes with
        matching editor color schemes, built around Livewire red (#F40B0B) and
        orange (#FFA500).
    ]]></description>
    <depends>com.intellij.modules.platform</depends>
    <extensions defaultExtensionNs="com.intellij">
        <themeProvider id="com.livewire.theme.dark" path="/themes/livewire-dark.theme.json" />
        <themeProvider id="com.livewire.theme.light" path="/themes/livewire-light.theme.json" />
    </extensions>
</idea-plugin>
