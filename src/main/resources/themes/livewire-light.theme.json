      "Checkbox.Background.Disabled": "#F3ECE5",
      "Checkbox.Border.Disabled": "#E0D3C7",
      "Checkbox.Foreground.Disabled": "#B4A79D",
      "Checkbox.Focus.Thin.Default": "#F1A695",
      "Checkbox.Focus.Thin.Selected": "#F1A695",
      "Checkbox.Focus.Wide": "#F1A695",
      "Actions.Red": "#C2170F",
